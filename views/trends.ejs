<%- include('partials/header') %>

    <div class="max-w-6xl mx-auto">
        <!-- Page Header -->
        <div class="text-center mb-12">
            <span
                class="inline-block py-1 px-3 rounded-full bg-blue-500/10 text-blue-400 text-sm font-semibold mb-4 border border-blue-500/20">Hot
                Topics</span>
            <h1 class="text-4xl md:text-5xl font-bold mb-4">Trending <span class="gradient-text">Now</span></h1>
            <p class="text-gray-400 text-lg max-w-2xl mx-auto">Discover the most discussed technologies, tutorials, and
                breakthroughs in the developer community this week.</p>
        </div>

        <!-- Trending Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% articles.forEach((article, index)=> { %>
                <div
                    class="bg-slate-900/50 rounded-xl overflow-hidden border border-slate-800 hover:border-blue-500/30 transition-all duration-300 group card-hover flex flex-col h-full">
                    <!-- Rank Badge -->
                    <div class="absolute top-4 left-4 z-10">
                        <span
                            class="flex items-center justify-center w-8 h-8 rounded-full bg-slate-900/90 text-white font-bold border border-slate-700 shadow-xl backdrop-blur-sm">
                            #<%= index + 1 %>
                        </span>
                    </div>

                    <div class="relative h-48 overflow-hidden">
                        <img src="<%= article.image %>" alt="<%= article.title %>"
                            class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 to-transparent"></div>
                    </div>

                    <div class="p-6 flex flex-col flex-grow">
                        <div class="flex flex-wrap gap-2 mb-4">
                            <% if(article.tags) { %>
                                <% article.tags.slice(0, 2).forEach(tag=> { %>
                                    <span
                                        class="text-xs font-medium px-2.5 py-0.5 rounded bg-blue-900/30 text-blue-300 border border-blue-500/20">
                                        #<%= tag %>
                                    </span>
                                    <% }); %>
                                        <% } %>
                        </div>

                        <h2 class="text-xl font-bold mb-3 line-clamp-2 group-hover:text-blue-400 transition-colors">
                            <a href="/article/<%= article.id %>">
                                <%= article.title %>
                            </a>
                        </h2>

                        <p class="text-gray-400 text-sm mb-4 line-clamp-3">
                            <%= article.summary %>
                        </p>

                        <div class="mt-auto flex items-center justify-between border-t border-slate-800 pt-4">
                            <div class="flex items-center space-x-2">
                                <div
                                    class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center text-xs font-bold text-gray-400">
                                    <%= article.author ? article.author[0] : 'A' %>
                                </div>
                                <span class="text-sm text-gray-400">
                                    <%= article.author %>
                                </span>
                            </div>
                            <span class="text-xs text-gray-500">
                                <%= article.date %>
                            </span>
                        </div>
                    </div>
                </div>
                <% }); %>
        </div>
    </div>

    <%- include('partials/footer') %>