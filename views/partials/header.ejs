<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | DevNews
    </title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;700&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #000000;
            /* Black */
            color: #f1f5f9;
            /* Slate 100 */
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            font-family: 'Outfit', sans-serif;
        }

        .gradient-text {
            background: linear-gradient(to right, #22d3ee, #818cf8, #c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .glass-nav {
            background: rgba(2, 6, 23, 0.6);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Removed main-gradient for better contrast */

        .card-hover:hover {
            transform: translateY(-4px);
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px -10px rgba(129, 140, 248, 0.15);
        }
    </style>
</head>

<body class="min-h-screen flex flex-col relative overflow-x-hidden animate-enter">

    <!-- Navbar -->
    <nav class="glass-nav fixed w-full z-50 top-0 start-0">
        <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
            <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse group">
                <div
                    class="w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-violet-500 flex items-center justify-center text-white font-bold text-lg shadow-lg group-hover:shadow-cyan-500/50 transition-all duration-300">
                    D
                </div>
                <span class="self-center text-2xl font-bold whitespace-nowrap text-white">Dev<span
                        class="gradient-text">News</span></span>
            </a>
            <div class="hidden w-full md:block md:w-auto" id="navbar-default">
                <ul
                    class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-gray-100 rounded-lg md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-transparent items-center">
                    <li>
                        <a href="/"
                            class="block py-2 px-3 text-white bg-blue-700 rounded md:bg-transparent md:text-gray-300 md:hover:text-white md:p-0 transition-colors"
                            aria-current="page">Home</a>
                    </li>
                    <li>
                        <a href="/trends"
                            class="block py-2 px-3 text-gray-300 rounded hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-white md:p-0 transition-colors">Trends</a>
                    </li>
                    <% if (user) { %>
                        <li>
                            <div class="flex items-center gap-2 py-2 px-3 md:p-0 text-gray-300">
                                <span class="w-2 h-2 rounded-full bg-green-500"></span>
                                <span>
                                    <%= user.username %>
                                </span>
                            </div>
                        </li>
                        <li>
                            <a href="/auth/logout"
                                class="block py-2 px-4 text-sm font-medium text-white bg-gray-800 hover:bg-gray-700 rounded-lg border border-gray-700 transition-colors">Logout</a>
                        </li>
                        <% } else { %>
                            <li class="flex gap-4">
                                <a href="/auth/login"
                                    class="py-2 px-4 text-sm font-medium text-gray-300 hover:text-white transition-colors">Login</a>
                                <a href="/auth/register"
                                    class="py-2 px-4 text-sm font-medium text-white bg-gradient-to-r from-blue-600 to-violet-600 rounded-lg hover:opacity-90 shadow-lg shadow-blue-500/20 transition-all">Get
                                    Started</a>
                            </li>
                            <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow container mx-auto px-4 pt-28 pb-12 z-10">